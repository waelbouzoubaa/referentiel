# ── Base de données ──────────────────────────────────────────────────────────
MIDDLEWARE_DATABASE_URL=postgresql+asyncpg://middleware:middleware@localhost:5432/middleware
MIDDLEWARE_DATABASE_ECHO=false

# ── Stockage objet (MinIO en dev, GCS en prod) ───────────────────────────────
MIDDLEWARE_STORAGE_ENDPOINT=http://localhost:9000
MIDDLEWARE_STORAGE_BUCKET=middleware-dev
MIDDLEWARE_STORAGE_ACCESS_KEY=minioadmin
MIDDLEWARE_STORAGE_SECRET_KEY=minioadmin
# En prod GCS : laisser endpoint vide et utiliser les credentials GCP

# ── Application ──────────────────────────────────────────────────────────────
MIDDLEWARE_DEBUG=false
MIDDLEWARE_LOG_LEVEL=INFO
MIDDLEWARE_ENVIRONMENT=development

# ── Dossiers locaux (dev) ────────────────────────────────────────────────────
MIDDLEWARE_INPUT_FOLDER=/data/input
MIDDLEWARE_OUTPUT_FOLDER=/data/output

# ── SharePoint (utilisé par le watcher, cf. projet Agent Référentiel) ────────
MIDDLEWARE_SHAREPOINT_HOST=
MIDDLEWARE_SHAREPOINT_SITE_PATH=/

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
